# =============================================================================
# Server
# =============================================================================

# Port the provisioning service listens on
PORT=3010

# =============================================================================
# Backend Service
# =============================================================================

# URL of the backend API (used for provisioning status callbacks)
# In-cluster: use K8s service DNS
BACKEND_URL=http://eu-jap-hack-backend:8000/api

# Max number of callback retry attempts on terminal status (ready / failed)
CALLBACK_MAX_RETRIES=10

# Fixed delay between callback retries (ms)
CALLBACK_RETRY_DELAY_MS=3000

# Per-request HTTP timeout for callback calls (ms)
CALLBACK_TIMEOUT_MS=10000

# =============================================================================
# PostgreSQL (shared EDC database server)
# =============================================================================

# Admin connection URL — used to CREATE DATABASE and USER per tenant
# Service: postgres.postgres-edc.svc.cluster.local:5432
POSTGRES_ADMIN_URL=postgresql://admin:secret@postgres.postgres-edc.svc.cluster.local:5432/postgres

# =============================================================================
# HashiCorp Vault
# =============================================================================

# Vault server URL (in-cluster)
VAULT_ADDR=http://vault.vault.svc.cluster.local:8200

# Vault token with write access to the provisioning path
VAULT_TOKEN=<vault-provisioning-token>

# =============================================================================
# Git Repository (for committing Helm values and Argo CD manifests)
# =============================================================================

# Absolute path to the cloned repo root inside the container
GIT_REPO_PATH=/repo

# Remote URL of the Git repository
GIT_REMOTE_URL=https://github.com/smartSenseSolutions/jap-eu-hack-2026

# GitHub Personal Access Token with contents:write permission
GIT_AUTH_TOKEN=<github-pat-with-contents-write>

# Git commit author identity
GIT_USER_NAME=edc-provisioning-bot
GIT_USER_EMAIL=edc-provisioning@the-sense.io

# =============================================================================
# Argo CD
# =============================================================================

# Argo CD source repoURL (must match what Argo CD can reach)
GIT_REPO_URL=https://github.com/smartSenseSolutions/jap-eu-hack-2026

# Argo CD server URL (in-cluster) — triggers immediate sync after Git commit
# Without this, Argo CD auto-sync picks up changes in ~3 min
ARGOCD_SERVER_URL=http://argocd-server.argocd.svc.cluster.local

# Argo CD API token with app:sync permission
ARGOCD_AUTH_TOKEN=<argocd-api-token>

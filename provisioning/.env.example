# Provisioning service — copy to .env and fill in values

PORT=3001

# Backend service URL (internal cluster DNS)
BACKEND_URL=http://backend-service.default.svc.cluster.local:3000

# Shared PostgreSQL on the cluster (admin credentials for CREATE DATABASE/USER)
# Example: postgresql://admin:secret@postgres.postgres.svc.cluster.local:5432/postgres
POSTGRES_ADMIN_URL=postgresql://admin:secret@localhost:5432/postgres

# HashiCorp Vault (in-cluster service URL)
VAULT_ADDR=http://vault.vault.svc.cluster.local:8200
VAULT_TOKEN=<vault-admin-or-provisioning-token>

# Git repository (for committing Helm values and Argo CD Application manifests)
# GIT_REPO_PATH is the absolute path to the repo root on this container
GIT_REPO_PATH=/Users/nitin/projects/smartsense/jap-eu-hack-2026
GIT_REMOTE_URL=https://github.com/smartSenseSolutions/jap-eu-hack-2026
GIT_AUTH_TOKEN=<github-pat-with-contents-write>
GIT_USER_NAME=edc-provisioning-bot
GIT_USER_EMAIL=edc-provisioning@the-sense.io

# Argo CD Application source.repoURL (must match what Argo CD can reach)
GIT_REPO_URL=https://github.com/smartSenseSolutions/jap-eu-hack-2026

# Argo CD (optional: for immediate sync after commit, otherwise auto-sync picks up in ~3 min)
ARGOCD_SERVER_URL=http://argocd-server.argocd.svc.cluster.local
ARGOCD_AUTH_TOKEN=<argocd-api-token>

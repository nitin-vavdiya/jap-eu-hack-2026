# =============================================================================
# Database
# =============================================================================

# PostgreSQL connection string (REQUIRED)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/eu_jap_hack

# =============================================================================
# Authentication
# =============================================================================
# JWT authentication via Keycloak is always enforced. Keycloak must be running.

# Keycloak base URL
KEYCLOAK_URL=http://localhost:8080

# Keycloak realm name
KEYCLOAK_REALM=eu-jap-hack

# Keycloak admin client ID (used for creating users during company onboarding)
KEYCLOAK_ADMIN_CLIENT_ID=realm_admin_client

# Keycloak admin client secret (required for admin operations)
KEYCLOAK_ADMIN_CLIENT_SECRET=your-admin-client-secret

# =============================================================================
# Walt.id Services
# =============================================================================

# Walt.id Wallet API URL
WALTID_WALLET_URL=http://localhost:7001

# Walt.id Issuer API URL
WALTID_ISSUER_URL=http://localhost:7002

# Walt.id Verifier API URL
WALTID_VERIFIER_URL=http://localhost:7003

# Optional HTTP timeout (ms) for Wallet API calls during operator bootstrap
# WALTID_HTTP_TIMEOUT_MS=15000

# HashiCorp Vault KV v2 — REQUIRED (company + operator wallet secrets). Matches docker-compose `vault` dev service.
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=dev-root-token
# VAULT_KV_MOUNT=secret
# Path segments are under the mount’s “data” API (no leading slash)
# VAULT_OPERATOR_WALLET_PATH=operator/wallet

# Operator walt.id wallet (Phase 8 — dev: password in env; prod: prefer Vault)
# OPERATOR_WALLET_EMAIL=operator@wallet.internal
# OPERATOR_WALLET_PASSWORD=change-me-in-dev-only-must-be-32-chars-min   # walt.id requires ≥32 chars (256-bit JWT secret)
# OPERATOR_WALLET_DISPLAY_NAME=SmartSense Operator
# Set to true to exit the process if bootstrap fails when password is set (default: false — log only)
# OPERATOR_WALLET_FAIL_ON_ERROR=false

# Per-company walt.id wallet is provisioned on POST /api/companies (Vault required for wallet secrets).

# OID4VCI credential_configuration_id for walt.id issuer-api (default: generic tutorial profile until you pin custom metadata).
# WALTID_DEFAULT_JWT_VC_CONFIGURATION_ID=UniversityDegree_jwt_vc_json
# Optional override for Membership issuance only (otherwise uses the default above).
# WALTID_MEMBERSHIP_CREDENTIAL_CONFIG_ID=UniversityDegree_jwt_vc_json

# =============================================================================
# Gaia-X Configuration
# =============================================================================
# Defaults and endpoint-set priority: backend/src/services/gaiax/config.ts
# Pin lab URLs + walt.id image digests for spikes: docs/agreements/001-ssi-implementation-agreement.md §6

# Set to true to use mock Gaia-X endpoints (no real compliance check)
GAIAX_MOCK_MODE=true

# Timeout for Gaia-X API calls (ms)
GAIAX_TIMEOUT=15000

# Number of retry attempts per Gaia-X request
GAIAX_RETRY_ATTEMPTS=2

# Delay between retries (ms)
GAIAX_RETRY_DELAY=1000

# Public domain for DID resolution (e.g. your ngrok or production domain, no https://)
GAIAX_DID_DOMAIN=jeh-api.tx.the-sense.io

# DID document path component (e.g. v1, v7)
GAIAX_DID_PATH=v1

# Override Gaia-X Lab endpoints (optional — must match backend/src/services/gaiax/config.ts LAB_SET)
# GAIAX_LAB_COMPLIANCE_URL=https://compliance.lab.gaia-x.eu/development
# GAIAX_LAB_REGISTRY_URL=https://registry.lab.gaia-x.eu/v2
# GAIAX_LAB_NOTARY_URL=https://registrationnumber.notary.lab.gaia-x.eu/v2

# Full URL for compliance ?vcid= (must return raw LegalParticipant VC-JWT). Use if ngrok-free HTML interstitial breaks resolution.
# GAIAX_COMPLIANCE_VCID_URL=https://example.com/static/my-lp.jwt

# VP POST Content-Type (default application/vp+ld+json+jwt to match typ; set application/vp+jwt if needed)
# GAIAX_COMPLIANCE_VP_CONTENT_TYPE=application/vp+jwt

# =============================================================================
# Application
# =============================================================================

# Public base URL of this backend (used for DID documents and EDC callbacks)
#
# REQUIRED in staging/production. RECOMMENDED in development (app starts with a warning if unset).
#
# For Gaia-X compliance verification to succeed, this MUST be a stable, publicly accessible
# HTTPS URL. The Gaia-X compliance service (compliance.lab.gaia-x.eu) resolves the company
# DID document at {APP_BASE_URL}/company/{id}/did.json. An ephemeral URL (ngrok, localhost)
# will cause Gaia-X verification to fail with "Unable to retrieve your DID".
#
# For local development with Gaia-X: use a stable reverse proxy or ngrok tunnel and update
# this value before running onboarding flows that require Gaia-X compliance.
APP_BASE_URL=http://localhost:8000

# =============================================================================
# EDC Provisioning
# =============================================================================

# Set to true to auto-provision an EDC instance on company onboarding
ENABLE_EDC_PROVISIONING=false

# URL of the EDC provisioning microservice
PROVISIONING_SERVICE_URL=http://localhost:3010

# Shared secret for internal service-to-service auth on the EDC provisioning callback.
# The provisioning microservice must send this as the X-Internal-Token header on
# PATCH /companies/:id/edc-provisioning requests.
# In production this must be set — requests are rejected with 503 if it is missing.
# In development (NODE_ENV != production) it can be omitted (warning logged, request allowed).
PROVISIONING_CALLBACK_SECRET=

# Node environment (controls dev-mode bypass for provisioning callback auth)
NODE_ENV=development

# Log level for the structured logger (RECOMMENDED)
# Valid values: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# Maximum number of companies allowed to onboard (leave unset for unlimited)
MAX_COMPANIES=10

# =============================================================================
# EDC (Eclipse Dataspace Connector) — Provider side
# =============================================================================

# Enable EDC integration for asset/car registration
ENABLE_EDC=true

# Provider EDC management API URL
EDC_BASE_URL=https://your-edc-instance.com

# Provider EDC API key
EDC_API_KEY=your-api-key

# Business Partner Number of this node
BPN_NUMBER=BPNL00000TATAMOTOR

# Access policy ID used when registering assets in EDC
EDC_ACCESS_POLICY_ID=policy_2

# Contract policy ID used when registering assets in EDC
EDC_CONTRACT_POLICY_ID=policy_2

# =============================================================================
# EDC — Consumer side (Insurance / Tokio Marine)
# =============================================================================

# Consumer EDC management API URL
EDC_CONSUMER_MANAGEMENT_URL=https://your-consumer-controlplane.example.com/management

# Consumer EDC API key
EDC_CONSUMER_API_KEY=your-consumer-api-key

# Initial delay before polling negotiation status (ms)
EDC_NEGOTIATION_INITIAL_DELAY_MS=5000

# Interval between negotiation status polls (ms)
EDC_NEGOTIATION_POLL_INTERVAL_MS=5000

# Max number of negotiation polling retries
EDC_NEGOTIATION_MAX_RETRIES=3

# =============================================================================
# CADDE (Cross-domain data exchange)
# =============================================================================

# Asset ID of the CADDE data offer
CADDE_ASSET_ID=your-cadde-asset-id

# Partner EDC DSP endpoint URL
CADDE_PARTNER_EDC_DSP_URL=https://partner-protocol.example.com/api/v1/dsp

# Partner Business Partner Number
CADDE_PARTNER_EDC_BPN=BPNL00000000XXXX
